generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model StudyDocument {
  id                     String          @id @default(cuid())
  ownerId                String          @db.Uuid
  originalFileName       String          @db.Text
  storedFileName         String          @unique
  fileSize               Int
  mimeType               String
  storageProvider        String          @default("local")
  storageBucket          String          @default("local")
  storageObjectKey       String          @db.Text
  contentSha256          String?         @db.VarChar(64)
  title                  String          @db.Text
  className              String?
  topic                  String?
  source                 String?
  documentDate           DateTime?       @db.Date
  tags                   String          @default("[]") @db.Text
  uploadStatus           String          @default("UPLOADING")
  pageCount              Int?
  failureStage           String?
  failureReason          String?         @db.Text
  storageConfirmedAt     DateTime?       @db.Timestamptz(6)
  processingStartedAt    DateTime?       @db.Timestamptz(6)
  processingCompletedAt  DateTime?       @db.Timestamptz(6)
  failedAt               DateTime?       @db.Timestamptz(6)
  deleteRequestedAt      DateTime?       @db.Timestamptz(6)
  processingAttemptCount Int             @default(0)
  createdAt              DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime        @updatedAt @db.Timestamptz(6)
  pages                  DocumentPage[]
  chunks                 DocumentChunk[]
  tagLinks               DocumentTag[]

  @@unique([storageProvider, storageBucket, storageObjectKey])
  @@index([ownerId, createdAt])
  @@index([ownerId, uploadStatus, createdAt])
  @@index([ownerId, className])
  @@index([ownerId, topic])
  @@index([ownerId, source])
  @@index([ownerId, documentDate])
  @@index([ownerId, contentSha256])
  @@index([ownerId, storageProvider, storageBucket, storageObjectKey])
  @@index([createdAt])
  @@index([uploadStatus])
  @@index([storageProvider])
  @@index([storageBucket])
  @@index([storageObjectKey])
  @@index([contentSha256])
  @@index([failureStage])
  @@index([className])
  @@index([topic])
  @@index([source])
  @@index([documentDate])
}

model DocumentPage {
  id         String        @id @default(cuid())
  documentId String
  pageNumber Int
  text       String        @db.Text
  createdAt  DateTime      @default(now()) @db.Timestamptz(6)
  document   StudyDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, pageNumber])
  @@index([documentId, pageNumber])
}

model DocumentChunk {
  id             String                  @id @default(cuid())
  documentId     String
  pageNumber     Int
  chunkIndex     Int
  text           String                  @db.Text
  characterCount Int
  tokenEstimate  Int
  createdAt      DateTime                @default(now()) @db.Timestamptz(6)
  document       StudyDocument           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  embedding      DocumentChunkEmbedding?

  @@unique([documentId, pageNumber, chunkIndex])
  @@index([documentId, pageNumber])
}

model DocumentChunkEmbedding {
  id             String                      @id @default(cuid())
  chunkId        String                      @unique
  embeddingModel String
  dimensions     Int
  vector         Unsupported("vector(1536)")
  contentHash    String
  createdAt      DateTime                    @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime                    @updatedAt @db.Timestamptz(6)
  chunk          DocumentChunk               @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@index([embeddingModel])
  @@index([dimensions])
  @@index([contentHash])
}

model Tag {
  id             String        @id @default(cuid())
  ownerId        String        @db.Uuid
  name           String
  normalizedName String
  createdAt      DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(6)
  documents      DocumentTag[]

  @@unique([ownerId, normalizedName])
  @@index([ownerId, name])
  @@index([name])
}

model DocumentTag {
  documentId String
  tagId      String
  createdAt  DateTime      @default(now()) @db.Timestamptz(6)
  document   StudyDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag        Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@index([tagId])
}
