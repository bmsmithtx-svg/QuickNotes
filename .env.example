# Local PostgreSQL/pgvector defaults for docker-compose.yml.
# For Supabase, set DATABASE_URL to the transaction-mode pooler and DIRECT_URL
# to the session-mode pooler. Keep real values in .env.local only.
DATABASE_URL=postgresql://quicknotes:quicknotes@localhost:54322/quicknotes?schema=public
DIRECT_URL=postgresql://quicknotes:quicknotes@localhost:54322/quicknotes?schema=public

# Optional: enables upload-time embeddings, semantic search, and hybrid search.
# Leave unset to keep uploads, document browsing, and keyword search working locally.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_EVAL_MODEL=

# PDF source storage. Use "local" for local development or "supabase" for durable private bucket storage.
QUICKNOTES_STORAGE_PROVIDER=local
QUICKNOTES_LOCAL_STORAGE_ROOT=
QUICKNOTES_LOCAL_STORAGE_BUCKET=local
# Defaults to 25 MB locally and 4 MB on Vercel. Keep Vercel values below the platform request body limit.
QUICKNOTES_MAX_PDF_UPLOAD_BYTES=

# Required when QUICKNOTES_STORAGE_PROVIDER=supabase.
# Use the server-only service-role key. Never expose this through a NEXT_PUBLIC_ variable.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=quicknotes-pdfs

# Required only when assigning pre-auth legacy documents during migration/import.
QUICKNOTES_LEGACY_OWNER_ID=

# Only set these for isolated test databases, never for shared development or production data.
QUICKNOTES_TEST_DATABASE=
QUICKNOTES_ALLOW_DESTRUCTIVE_DB=
