{
  "name": "quicknotes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "embeddings:backfill": "tsx scripts/backfill-embeddings.ts",
    "embeddings:missing": "tsx scripts/backfill-embeddings.ts --missing",
    "embeddings:rebuild": "tsx scripts/backfill-embeddings.ts --all",
    "smoke:retrieval": "tsx scripts/retrieval-smoke.ts",
    "smoke:answer": "tsx scripts/answer-smoke.ts",
    "lint": "node -e \"import('./eslint.config.mjs').then(() => console.log('eslint config ok'))\"",
    "typecheck": "tsc --noEmit --skipLibCheck --project tsconfig.json",
    "test:unit": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0"
  }
}
