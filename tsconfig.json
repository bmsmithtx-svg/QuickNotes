{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "files": [
    "src/lib/types.ts",
    "src/lib/chunking.ts",
    "src/lib/chunking.test.ts",
    "src/lib/sample-data.ts",
    "src/app/layout.tsx",
    "src/app/page.tsx",
    "src/components/quicknotes-workspace.tsx"
  ]
}
